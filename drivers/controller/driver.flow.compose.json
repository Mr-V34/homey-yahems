{
  "triggers": [
    {
      "id": "signal_stale",
      "title": { "en": "A sensor signal went stale", "sv": "En sensorsignal blev inaktuell" },
      "titleFormatted": { "en": "A sensor signal went stale", "sv": "En sensorsignal blev inaktuell" },
      "hint": {
        "en": "Fires when a sensor signal has not changed for the staleness window. YAHEMS holds at DEFCON 3 until the signal recovers.",
        "sv": "Utlöses när en sensorsignal inte förändrats under tidsfönstret. YAHEMS håller DEFCON 3 tills signalen återhämtar sig."
      },
      "tokens": [
        {
          "name": "signal",
          "type": "string",
          "title": { "en": "Signal", "sv": "Signal" },
          "example": "House power"
        }
      ]
    },
    {
      "id": "defcon_changed",
      "title": { "en": "DEFCON changed", "sv": "DEFCON ändrades" },
      "titleFormatted": { "en": "DEFCON changed", "sv": "DEFCON ändrades" },
      "hint": { "en": "Fires when the whole-home DEFCON level changes.", "sv": "Utlöses när husets DEFCON-nivå ändras." },
      "tokens": [
        { "name": "defcon", "type": "number", "title": { "en": "DEFCON", "sv": "DEFCON" }, "example": 3 },
        { "name": "mode", "type": "string", "title": { "en": "Mode", "sv": "Läge" }, "example": "advisory" }
      ]
    },
    {
      "id": "red_alert",
      "title": { "en": "Critical peak started", "sv": "Kritisk topp startade" },
      "titleFormatted": { "en": "Critical peak started", "sv": "Kritisk topp startade" },
      "hint": { "en": "Fires when DEFCON reaches 1.", "sv": "Utlöses när DEFCON når 1." }
    }
  ],
  "conditions": [
    {
      "id": "defcon_lte",
      "title": { "en": "DEFCON is at or below level", "sv": "DEFCON är på eller under nivå" },
      "titleFormatted": { "en": "DEFCON is [[level]] or lower", "sv": "DEFCON är [[level]] eller lägre" },
      "args": [
        {
          "type": "dropdown",
          "name": "level",
          "values": [
            { "id": "5", "label": { "en": "5", "sv": "5" } },
            { "id": "4", "label": { "en": "4", "sv": "4" } },
            { "id": "3", "label": { "en": "3", "sv": "3" } },
            { "id": "2", "label": { "en": "2", "sv": "2" } },
            { "id": "1", "label": { "en": "1", "sv": "1" } }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "report_grid_power",
      "title": { "en": "Report grid power", "sv": "Rapportera näteffekt" },
      "titleFormatted": { "en": "Report grid power [[power]] W", "sv": "Rapportera näteffekt [[power]] W" },
      "hint": { "en": "Feed your meter reading here, positive = importing from grid.", "sv": "Mata in din mätaravläsning här, positivt = import från nätet." },
      "args": [
        { "type": "number", "name": "power", "title": { "en": "Watts", "sv": "Watt" }, "placeholder": { "en": "W", "sv": "W" } }
      ]
    },
    {
      "id": "set_anchor",
      "title": { "en": "Set power target", "sv": "Sätt effekttak" },
      "titleFormatted": { "en": "Set power target to [[watts]] W", "sv": "Sätt effekttak till [[watts]] W" },
      "args": [
        { "type": "number", "name": "watts", "title": { "en": "Watts", "sv": "Watt" } }
      ]
    },
    {
      "id": "run_now",
      "title": { "en": "Run all now", "sv": "Kör allt nu" },
      "titleFormatted": { "en": "Run all now", "sv": "Kör allt nu" },
      "hint": { "en": "Temporarily allow all loads to run.", "sv": "Tillåt tillfälligt alla laster att köra." }
    },
    {
      "id": "boost_for_hours",
      "title": { "en": "Boost load for hours", "sv": "Boosta last i timmar" },
      "titleFormatted": { "en": "Boost [[load]] for [[hours]] h", "sv": "Boosta [[load]] i [[hours]] h" },
      "hint": {
        "en": "Run this load at full setpoints for the specified number of hours, bypassing the price gate. All safety layers still apply.",
        "sv": "Kör denna last med fulla börvärden i angivet antal timmar, förbi prisporten. Alla säkerhetslager gäller fortfarande."
      },
      "args": [
        {
          "type": "dropdown",
          "name": "load",
          "title": { "en": "Load", "sv": "Last" },
          "values": [
            { "id": "nibe",       "label": { "en": "Heat pump",         "sv": "Värmepump" } },
            { "id": "spa",        "label": { "en": "Spa",               "sv": "Spabad" } },
            { "id": "ev",         "label": { "en": "EV charger",        "sv": "Elbilsladdare" } },
            { "id": "battery",    "label": { "en": "Battery",           "sv": "Hembatteri" } },
            { "id": "appliances", "label": { "en": "Appliances",        "sv": "Vitvaror" } }
          ]
        },
        {
          "type": "number",
          "name": "hours",
          "title": { "en": "Hours", "sv": "Timmar" },
          "placeholder": { "en": "e.g. 2", "sv": "t.ex. 2" },
          "min": 0
        }
      ]
    },
    {
      "id": "boost_until",
      "title": { "en": "Boost load until time", "sv": "Boosta last till klockslag" },
      "titleFormatted": { "en": "Boost [[load]] until [[time]]", "sv": "Boosta [[load]] till [[time]]" },
      "hint": {
        "en": "Run this load at full setpoints until the specified local time (today if still ahead, else tomorrow), bypassing the price gate. All safety layers still apply.",
        "sv": "Kör denna last med fulla börvärden till angivet klockslag (idag om det är framåt, annars imorgon), förbi prisporten. Alla säkerhetslager gäller fortfarande."
      },
      "args": [
        {
          "type": "dropdown",
          "name": "load",
          "title": { "en": "Load", "sv": "Last" },
          "values": [
            { "id": "nibe",       "label": { "en": "Heat pump",         "sv": "Värmepump" } },
            { "id": "spa",        "label": { "en": "Spa",               "sv": "Spabad" } },
            { "id": "ev",         "label": { "en": "EV charger",        "sv": "Elbilsladdare" } },
            { "id": "battery",    "label": { "en": "Battery",           "sv": "Hembatteri" } },
            { "id": "appliances", "label": { "en": "Appliances",        "sv": "Vitvaror" } }
          ]
        },
        {
          "type": "time",
          "name": "time",
          "title": { "en": "Until", "sv": "Till" }
        }
      ]
    },
    {
      "id": "cancel_boost",
      "title": { "en": "Cancel boost for load", "sv": "Avbryt boost för last" },
      "titleFormatted": { "en": "Cancel boost for [[load]]", "sv": "Avbryt boost för [[load]]" },
      "hint": {
        "en": "Cancel an active boost for this load, returning it to normal DEFCON-managed behaviour immediately.",
        "sv": "Avbryt aktiv boost för denna last och återgå omedelbart till normalt DEFCON-styrt beteende."
      },
      "args": [
        {
          "type": "dropdown",
          "name": "load",
          "title": { "en": "Load", "sv": "Last" },
          "values": [
            { "id": "nibe",       "label": { "en": "Heat pump",         "sv": "Värmepump" } },
            { "id": "spa",        "label": { "en": "Spa",               "sv": "Spabad" } },
            { "id": "ev",         "label": { "en": "EV charger",        "sv": "Elbilsladdare" } },
            { "id": "battery",    "label": { "en": "Battery",           "sv": "Hembatteri" } },
            { "id": "appliances", "label": { "en": "Appliances",        "sv": "Vitvaror" } }
          ]
        }
      ]
    }
  ]
}
