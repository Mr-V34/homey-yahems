  "flow": {
    "triggers": [
      {
        "id": "signal_stale",
        "title": {
          "en": "A sensor signal went stale",
          "sv": "En sensorsignal blev inaktuell"
        },
        "titleFormatted": {
          "en": "Sensor [[signal]] went stale",
          "sv": "Sensor [[signal]] blev inaktuell"
        },
        "hint": {
          "en": "Fires when a sensor signal has not changed for the staleness window. YAHEMS holds at DEFCON 3 until the signal recovers.",
          "sv": "Utlöses när en sensorsignal inte förändrats under tidsfönstret. YAHEMS håller DEFCON 3 tills signalen återhämtar sig."
        },
        "tokens": [
          {
            "name": "signal",
            "type": "string",
            "title": {
              "en": "Signal",
              "sv": "Signal"
            },
            "example": "consumptionW"
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=controller"
          }
        ]
      },
      {
        "id": "defcon_changed",
        "title": {
          "en": "DEFCON changed",
          "sv": "DEFCON ändrades"
        },
        "titleFormatted": {
          "en": "DEFCON changed",
          "sv": "DEFCON ändrades"
        },
        "hint": {
          "en": "Fires when the whole-home DEFCON level changes.",
          "sv": "Utlöses när husets DEFCON-nivå ändras."
        },
        "tokens": [
          {
            "name": "defcon",
            "type": "number",
            "title": {
              "en": "DEFCON",
              "sv": "DEFCON"
            },
            "example": 3
          },
          {
            "name": "mode",
            "type": "string",
            "title": {
              "en": "Mode",
              "sv": "Läge"
            },
            "example": "advisory"
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=controller"
          }
        ]
      },
      {
        "id": "red_alert",
        "title": {
          "en": "Critical peak started",
          "sv": "Kritisk topp startade"
        },
        "titleFormatted": {
          "en": "Critical peak started",
          "sv": "Kritisk topp startade"
        },
        "hint": {
          "en": "Fires when DEFCON reaches 1.",
          "sv": "Utlöses när DEFCON når 1."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=controller"
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "defcon_lte",
        "title": {
          "en": "DEFCON is at or below level",
          "sv": "DEFCON är på eller under nivå"
        },
        "titleFormatted": {
          "en": "DEFCON is [[level]] or lower",
          "sv": "DEFCON är [[level]] eller lägre"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=controller"
          },
          {
            "type": "dropdown",
            "name": "level",
            "values": [
              {
                "id": "5",
                "label": {
                  "en": "5",
                  "sv": "5"
                }
              },
              {
                "id": "4",
                "label": {
                  "en": "4",
                  "sv": "4"
                }
              },
              {
                "id": "3",
                "label": {
                  "en": "3",
                  "sv": "3"
                }
              },
              {
                "id": "2",
                "label": {
                  "en": "2",
                  "sv": "2"
                }
              },
              {
                "id": "1",
                "label": {
                  "en": "1",
                  "sv": "1"
                }
              }
            ]
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "report_grid_power",
        "title": {
          "en": "Report grid power",
          "sv": "Rapportera näteffekt"
        },
        "titleFormatted": {
          "en": "Report grid power [[power]] W",
          "sv": "Rapportera näteffekt [[power]] W"
        },
        "hint": {
          "en": "Feed your meter reading here, positive = importing from grid.",
          "sv": "Mata in din mätaravläsning här, positivt = import från nätet."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=controller"
          },
          {
            "type": "number",
            "name": "power",
            "title": {
              "en": "Watts",
              "sv": "Watt"
            },
            "placeholder": {
              "en": "W",
              "sv": "W"
            }
          }
        ]
      },
      {
        "id": "set_anchor",
        "title": {
          "en": "Set power target",
          "sv": "Sätt effekttak"
        },
        "titleFormatted": {
          "en": "Set power target to [[watts]] W",
          "sv": "Sätt effekttak till [[watts]] W"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=controller"
          },
          {
            "type": "number",
            "name": "watts",
            "title": {
              "en": "Watts",
              "sv": "Watt"
            }
          }
        ]
      },
      {
        "id": "run_now",
        "title": {
          "en": "Run all now",
          "sv": "Kör allt nu"
        },
        "titleFormatted": {
          "en": "Run all now",
          "sv": "Kör allt nu"
        },
        "hint": {
          "en": "Temporarily allow all loads to run.",
          "sv": "Tillåt tillfälligt alla laster att köra."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=controller"
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "YAHEMS Controller",
        "sv": "YAHEMS-styrenhet"
      },
      "class": "other",
      "capabilities": [
        "yahems_defcon",
        "yahems_mode",
        "measure_power",
        "yahems_fault"
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [],
      "images": {
        "small": "/drivers/controller/assets/images/small.png",
        "large": "/drivers/controller/assets/images/large.png",
        "xlarge": "/drivers/controller/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "id": "controller",
      "settings": [
        {
          "id": "anchor",
          "type": "number",
          "label": {
            "en": "Power target (W)",
            "sv": "Effekttak (W)"
          },
          "hint": {
            "en": "Net grid import above this is DEFCON 1. Bands are thirds of this value.",
            "sv": "Nettoimport över detta är DEFCON 1. Banden är tredjedelar av detta."
          },
          "value": 4500,
          "min": 500,
          "max": 20000
        },
        {
          "id": "house_meter_present",
          "type": "checkbox",
          "label": {
            "en": "Real house meter connected",
            "sv": "Riktig husmätare ansluten"
          },
          "hint": {
            "en": "Switches from Advisory to Control. Keep off until YAHEMS can see real house consumption.",
            "sv": "Växlar från Rådgivande till Styrning. Håll av tills YAHEMS ser verklig husförbrukning."
          },
          "value": false
        },
        {
          "id": "device_map",
          "type": "textarea",
          "label": {
            "en": "Device map (JSON)",
            "sv": "Enhetskarta (JSON)"
          },
          "hint": {
            "en": "Maps your physical Homey devices to YAHEMS canonical signals. Each entry needs a signal key, a Homey device ID, and a capability ID. Leave empty to run on flow-action input only.",
            "sv": "Kopplar dina fysiska Homey-enheter till YAHEMS kanoniska signaler. Varje rad kräver en signalnyckel, ett Homey-enhets-ID och ett förmåge-ID. Lämna tomt för att köra enbart på flödesåtgärdsdata."
          },
          "value": "{\"inputs\":[],\"control\":{\"house_meter_present\":false}}"
        }
      ]
    }
  ],
  "capabilities": {
    "yahems_defcon": {
      "type": "number",
      "title": {
        "en": "DEFCON",
        "sv": "DEFCON"
      },
      "desc": {
