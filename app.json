      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false,
      "values": [
        {
          "id": "advisory",
          "title": {
            "en": "Advisory",
            "sv": "Rådgivande"
          }
        },
        {
          "id": "control",
          "title": {
            "en": "Control",
            "sv": "Styrning"
