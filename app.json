      "type": "number",
      "title": {
        "en": "DEFCON",
        "sv": "DEFCON"
      },
      "desc": {
        "en": "Whole-home energy status, 5 (calm) to 1 (critical peak).",
        "sv": "Husets energistatus, 5 (lugnt) till 1 (kritisk topp)."
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true,
      "min": 1,
      "max": 5,
      "step": 1,
      "decimals": 0,
      "icon": "/assets/icon.svg"
    },
    "yahems_fault": {
      "type": "boolean",
      "title": {
        "en": "Sensor fault",
        "sv": "Sensorfel"
