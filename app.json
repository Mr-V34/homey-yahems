      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true,
      "min": 1,
      "max": 5,
      "step": 1,
      "decimals": 0,
      "icon": "/assets/icon.svg"
    },
    "yahems_fault": {
      "type": "boolean",
      "title": {
        "en": "Sensor fault",
        "sv": "Sensorfel"
      },
      "uiComponent": "sensor",
