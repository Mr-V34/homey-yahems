      "insights": true,
      "icon": "/assets/icon.svg"
    },
    "yahems_mode": {
      "type": "enum",
      "title": {
        "en": "Mode",
        "sv": "Läge"
      },
      "desc": {
        "en": "Advisory (read-only) until a real house meter is connected, then Control.",
        "sv": "Rådgivande (läsläge) tills en riktig husmätare finns, sedan Styrning."
